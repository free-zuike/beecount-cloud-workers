# Cloudflare Workers 本地开发配置
# 将此文件复制为 .dev.vars 并填入真实的值

# JWT Secret (用于签名和验证 JWT tokens)
# 重要：本地开发可以使用这个默认的 secret，但生产环境必须使用强密码
JWT_SECRET="YBt6MxIcvuWIA3kE/MPHuWPCFEcaCBPB80YxZM5hBaw="

# API 前缀（通常不需要修改）
API_PREFIX="/api/v1"

# 可选：S3 配置（如果需要文件上传功能）
# S3_ENDPOINT="https://your-s3-endpoint"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="your-access-key-id"
# S3_SECRET_ACCESS_KEY="your-secret-access-key"
# S3_BUCKET_NAME="beecount-attachments"
